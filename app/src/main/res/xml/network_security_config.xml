<?xml version="1.0" encoding="utf-8"?>
<!-- ANDROID 8 FIX: Explicitly block cleartext traffic on API 26-27 (API 28+ blocks by default) -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
